    id
    numerocheque
    numeroCompte
    datevalidite

    TABLE etatcheque
    id
    etat (ok, vole)

    TABLE cheque etat
    id
    idcheque
    idetat
    date
    porteur

    si cheque existe [ok]
    exception si cheque incorrect (date ou autre) [ok]
    verifier si cheque vole ou deja encaisse [ok]
    solde